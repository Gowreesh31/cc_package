# ── Gemini AI ─────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── App URL ───────────────────────────────────────────────
APP_URL="http://YOUR_EC2_PUBLIC_IP"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ── Sessions ──────────────────────────────────────────────
SESSION_SECRET="replace_this_with_a_long_random_secret"

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB="supply_chain"
POSTGRES_USER="sc_user"
POSTGRES_PASSWORD="sc_password"
DATABASE_URL="postgresql://sc_user:sc_password@postgres:5432/supply_chain?schema=public"

# ── Seed Defaults ─────────────────────────────────────────
SEED_DEFAULT_PASSWORD="password"
